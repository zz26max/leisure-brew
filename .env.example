# 复制为 .env 后再填写。不要把 .env 提交到版本库。

# 本地端口
FRONTEND_PORT=80
BACKEND_PORT=8080
MYSQL_PORT=3307
REDIS_PORT=6380

# 数据存储
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
REDIS_PASSWORD=

# 分别生成两个不同的随机值，每个至少 32 字节。
JWT_ADMIN_SECRET_KEY=
JWT_USER_SECRET_KEY=

# 仅供本地走通下单流程；正式环境必须设为 false。
PAYMENT_SIMULATION_ENABLED=true

# 可选：对象存储与微信能力。不使用时保持为空即可。
SKY_ALIOSS_ENDPOINT=
SKY_ALIOSS_ACCESS_KEY_ID=
SKY_ALIOSS_ACCESS_KEY_SECRET=
SKY_ALIOSS_BUCKET_NAME=
SKY_WECHAT_APPID=
SKY_WECHAT_SECRET=
SKY_WECHAT_MCHID=
SKY_WECHAT_MCHSERIALNO=
SKY_WECHAT_APIV3KEY=
SKY_WECHAT_NOTIFYURL=
SKY_WECHAT_REFUNDNOTIFYURL=
