.address-edit__heading {
  display: flex;
  margin-bottom: 34rpx;
  flex-direction: column;
}
.address-form {
  padding: 8rpx 28rpx;
}
.address-form label,
.choice-row,
.picker-row {
  display: grid;
  grid-template-columns: 150rpx 1fr;
  min-height: 104rpx;
  align-items: center;
  border-bottom: 1rpx solid var(--line);
}
.address-form label > text,
.choice-row > text,
.picker-row > text:first-child {
  color: var(--muted);
  font-size: 23rpx;
}
.address-form input {
  height: 80rpx;
  font-size: 26rpx;
}
.choice-row > view {
  display: flex;
  gap: 14rpx;
}
.choice-row button {
  padding: 14rpx 24rpx;
  color: var(--muted);
  background: var(--rice-100);
  border-radius: 28rpx;
  font-size: 22rpx;
}
.choice-row button.active {
  color: var(--tea-700);
  background: var(--tea-100);
}
.picker-row {
  grid-template-columns: 150rpx 1fr auto;
}
.picker-row .placeholder {
  color: #a8ada9;
}
.detail-field {
  display: block !important;
  padding: 26rpx 0;
}
.detail-field > text {
  display: block;
}
.detail-field textarea {
  width: 100%;
  height: 130rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  background: var(--rice-100);
  border-radius: 18rpx;
  font-size: 24rpx;
}
.save-button {
  margin-top: 32rpx;
}
