.menu-page {
  padding-bottom: 150rpx;
}
.menu-hero {
  position: relative;
  min-height: 360rpx;
  overflow: hidden;
  padding: 46rpx 34rpx;
  color: #fff;
  background: var(--tea-900);
  border-radius: 0 0 48rpx 48rpx;
}
.menu-hero__brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}
.menu-hero__brand .seal {
  display: grid;
  width: 66rpx;
  height: 66rpx;
  color: var(--tea-900);
  background: var(--jasmine);
  border-radius: 20rpx 20rpx 20rpx 6rpx;
  place-items: center;
  font-family: STSong, serif;
  font-size: 36rpx;
}
.menu-hero__brand > view:last-child {
  display: flex;
  flex-direction: column;
}
.menu-hero__brand > view text:first-child {
  font-family: STSong, serif;
  font-size: 30rpx;
  letter-spacing: 5rpx;
}
.menu-hero__brand > view text:last-child {
  margin-top: 4rpx;
  font-size: 14rpx;
  letter-spacing: 5rpx;
  opacity: 0.55;
}
.menu-hero__season {
  display: block;
  margin-top: 60rpx;
  color: var(--jasmine);
  font-size: 20rpx;
  letter-spacing: 4rpx;
}
.menu-hero__title {
  display: block;
  margin-top: 12rpx;
  font-family: STSong, serif;
  font-size: 52rpx;
  letter-spacing: 3rpx;
}
.menu-hero__copy {
  display: block;
  width: 470rpx;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 23rpx;
  line-height: 1.7;
}
.menu-hero__flower {
  position: absolute;
  right: 65rpx;
  bottom: 55rpx;
  width: 100rpx;
  height: 100rpx;
}
.petal {
  position: absolute;
  top: 38rpx;
  left: 36rpx;
  width: 34rpx;
  height: 52rpx;
  background: rgba(255, 255, 255, 0.84);
  border-radius: 50% 50% 45% 45%;
  transform-origin: 17rpx 12rpx;
}
.p1 {
  transform: rotate(0deg) translateY(-28rpx);
}
.p2 {
  transform: rotate(72deg) translateY(-28rpx);
}
.p3 {
  transform: rotate(144deg) translateY(-28rpx);
}
.p4 {
  transform: rotate(216deg) translateY(-28rpx);
}
.p5 {
  transform: rotate(288deg) translateY(-28rpx);
}
.core {
  position: absolute;
  z-index: 2;
  top: 38rpx;
  left: 38rpx;
  width: 26rpx;
  height: 26rpx;
  background: var(--jasmine);
  border-radius: 50%;
}
.closed-banner {
  display: flex;
  margin: 24rpx 28rpx 0;
  padding: 24rpx 28rpx;
  background: var(--rice-100);
  border-radius: 24rpx;
  flex-direction: column;
}
.closed-banner text:first-child {
  font-weight: 700;
}
.closed-banner text:last-child {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
}
.category-strip {
  width: auto;
  padding: 30rpx 28rpx 20rpx;
  white-space: nowrap;
}
.category-pill {
  display: inline-flex;
  height: 64rpx;
  align-items: center;
  margin-right: 14rpx;
  padding: 0 28rpx;
  color: var(--muted);
  background: var(--rice-100);
  border-radius: 32rpx;
  font-size: 24rpx;
}
.category-pill.active {
  color: #fff;
  background: var(--tea-700);
}
.menu-list {
  display: grid;
  gap: 20rpx;
  padding: 0 28rpx;
}
.product-card {
  display: grid;
  grid-template-columns: 210rpx 1fr;
  overflow: hidden;
  color: var(--ink);
  background: #fffefa;
  border: 1rpx solid var(--line);
  border-radius: 30rpx;
  text-align: left;
}
.product-card__image {
  position: relative;
  display: grid;
  width: 210rpx;
  height: 210rpx;
  color: var(--tea-700);
  background: var(--rice-100);
  place-items: center;
  font-family: STSong, serif;
  font-size: 50rpx;
}
.product-card__image image {
  width: 100%;
  height: 100%;
}
.product-card__image view {
  position: absolute;
  inset: 0;
  display: grid;
  color: white;
  background: rgba(23, 63, 53, 0.65);
  place-items: center;
  font-size: 22rpx;
}
.product-card__body {
  display: flex;
  justify-content: space-between;
  padding: 26rpx;
  flex-direction: column;
}
.product-card__name {
  display: block;
  font-family: STSong, serif;
  font-size: 31rpx;
  font-weight: 600;
}
.product-card__description {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  color: var(--muted);
  font-size: 21rpx;
  line-height: 1.55;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
.product-card__foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.product-card__foot .price {
  font-size: 30rpx;
}
.add-button {
  display: grid;
  width: 54rpx;
  height: 54rpx;
  color: #fff;
  background: var(--tea-700);
  border-radius: 50%;
  place-items: center;
  font-size: 34rpx;
}
.add-button[disabled] {
  background: #adb7b2;
}
.floating-cart {
  position: fixed;
  z-index: 20;
  right: 28rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  left: 28rpx;
  display: grid;
  grid-template-columns: 1fr auto auto;
  align-items: center;
  gap: 24rpx;
  height: 96rpx;
  padding: 0 30rpx;
  color: #fff;
  background: var(--tea-900);
  border-radius: 48rpx;
  box-shadow: 0 18rpx 40rpx rgba(23, 63, 53, 0.25);
}
.floating-cart > view {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.floating-cart > view text:first-child {
  display: grid;
  width: 42rpx;
  height: 42rpx;
  color: var(--tea-900);
  background: var(--jasmine);
  border-radius: 50%;
  place-items: center;
  font-size: 20rpx;
}
.floating-cart strong {
  font-family: Georgia, serif;
}
.floating-cart > text {
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
}
.sheet-mask {
  position: fixed;
  z-index: 50;
  inset: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 30, 25, 0.48);
}
.product-sheet {
  width: 100%;
  max-height: 82vh;
  overflow-y: auto;
  padding: 18rpx 32rpx calc(34rpx + env(safe-area-inset-bottom));
  background: var(--rice-50);
  border-radius: 42rpx 42rpx 0 0;
}
.sheet-handle {
  width: 70rpx;
  height: 8rpx;
  margin: 0 auto 28rpx;
  background: var(--line);
  border-radius: 4rpx;
}
.product-sheet__heading {
  display: grid;
  grid-template-columns: 180rpx 1fr;
  gap: 24rpx;
}
.product-sheet__heading image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx;
}
.product-sheet__heading > view {
  display: flex;
  flex-direction: column;
}
.product-sheet__heading > view > text:first-child {
  font-family: STSong, serif;
  font-size: 36rpx;
  font-weight: 600;
}
.product-sheet__heading > view > text:nth-child(2) {
  margin: 10rpx 0;
  color: var(--muted);
  font-size: 22rpx;
}
.flavor-group {
  margin: 34rpx 0;
}
.flavor-group > text {
  font-weight: 600;
}
.flavor-group > view {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}
.flavor-group button {
  padding: 16rpx 26rpx;
  color: var(--muted);
  background: var(--rice-100);
  border: 1rpx solid var(--line);
  border-radius: 30rpx;
}
.flavor-group button.selected {
  color: var(--tea-700);
  background: var(--tea-100);
  border-color: var(--tea-700);
}
.skeleton {
  height: 210rpx;
  background: linear-gradient(90deg, #f1ede4, #faf8f2, #f1ede4);
  background-size: 200% 100%;
  border-radius: 30rpx;
  animation: shimmer 1.3s infinite;
}
@keyframes shimmer {
  to {
    background-position: -200% 0;
  }
}
