# 数据源配置
sky:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    host: localhost
    port: 3306
    database: sky_take_out
    username: your_mysql_username
    password: your_mysql_password

  # 阿里云 OSS 配置
  alioss:
    endpoint: oss-cn-hangzhou.aliyuncs.com
    access-key-id: your_aliyun_access_key_id
    access-key-secret: your_aliyun_access_key_secret
    bucket-name: your_bucket_name

  # Redis 配置
  redis:
    localhost: localhost
    port: 6379
    password: your_redis_password
    database: 1

  # JWT 密钥配置
  jwt:
    admin-secret-key: your_admin_secret_key
    user-secret-key: your_user_secret_key

  # 微信小程序 & 微信支付配置
  wechat:
    appid: your_wechat_appid
    secret: your_wechat_secret
    mchid: your_wechat_mchid
    mchSerialNo: your_wechat_mch_serial_no
    apiV3Key: your_wechat_api_v3_key
    notifyUrl: https://your-domain.com/notify/paySuccess
    refundNotifyUrl: https://your-domain.com/notify/refundSuccess
