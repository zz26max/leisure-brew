# 数据源配置
sky:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    host: localhost
    port: 3307
    database: meal_buddy
    username: leisure_brew
    password: ${MYSQL_PASSWORD}

  # 阿里云 OSS 配置
  alioss:
    endpoint: ${SKY_ALIOSS_ENDPOINT:}
    access-key-id: ${SKY_ALIOSS_ACCESS_KEY_ID:}
    access-key-secret: ${SKY_ALIOSS_ACCESS_KEY_SECRET:}
    bucket-name: ${SKY_ALIOSS_BUCKET_NAME:}

  # Redis 配置
  redis:
    localhost: localhost
    port: 6379
    password: ${REDIS_PASSWORD}
    database: 0

  # JWT 密钥配置
  jwt:
    admin-secret-key: ${JWT_ADMIN_SECRET_KEY}
    user-secret-key: ${JWT_USER_SECRET_KEY}

  # 本地模拟支付；接入真实支付前必须关闭。
  payment:
    simulation-enabled: ${SKY_PAYMENT_SIMULATION_ENABLED:false}

  # 微信小程序 & 微信支付配置
  wechat:
    appid: ${SKY_WECHAT_APPID:}
    secret: ${SKY_WECHAT_SECRET:}
    mchid: ${SKY_WECHAT_MCHID:}
    mchSerialNo: ${SKY_WECHAT_MCHSERIALNO:}
    apiV3Key: ${SKY_WECHAT_APIV3KEY:}
    notifyUrl: ${SKY_WECHAT_NOTIFYURL:}
    refundNotifyUrl: ${SKY_WECHAT_REFUNDNOTIFYURL:}
