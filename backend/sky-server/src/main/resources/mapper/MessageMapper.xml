<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sky.mapper.MessageMapper">

    <select id="pageQuery" resultType="com.sky.entity.Message">
        select * from message
        <where>
            <if test="status != null">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <update id="updateStatusBatch">
        update message set status = #{param2} where id in
        <foreach collection="param1" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </update>

</mapper>
